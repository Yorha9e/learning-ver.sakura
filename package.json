{
  "name": "learning-ver.sakura",
  "version": "0.1.1",
  "description": "AI-powered recursive learning system with project-aware skill generation, Socratic method and TDD practice",
  "keywords": [
    "learn-anything",
    "learning",
    "cli",
    "ai",
    "education",
    "socratic",
    "tdd",
    "project-aware",
    "sakura"
  ],
  "homepage": "https://github.com/yorha9e/learning-ver.sakura",
  "repository": {
    "type": "git",
    "url": "https://github.com/yorha9e/learning-ver.sakura"
  },
  "license": "MIT",
  "author": "yorha9e",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "learning-sakura": "./bin/learn-anything.js"
  },
  "files": [
    "dist",
    "bin",
    "!dist/**/*.test.js",
    "!dist/**/__tests__",
    "!dist/**/*.map"
  ],
  "scripts": {
    "build": "node build.js",
    "dev": "tsc --watch",
    "dev:cli": "pnpm build && node bin/learn-anything.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "prepublishOnly": "pnpm run build"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "devDependencies": {
    "@types/node": "^24.2.0",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.1",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.8.0",
    "boxen": "^8.0.1",
    "chalk": "^5.5.0",
    "commander": "^14.0.0",
    "fast-glob": "^3.3.3",
    "ora": "^9.4.0",
    "yaml": "^2.8.2",
    "zod": "^4.0.17"
  }
}
